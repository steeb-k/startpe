[Main]
Title=StartPE
Description=A free, open source (GPLv3) taskbar and start menu for Windows PE. Drop-in alternative to StartAllBack/StartIsBack++.
Author=steeb-k
Level=3
Selected=True
Mandatory=False
Version=0.1.53.0
Date=2026-06-13

[Variables]
%ProgramFolder%=StartPE
%BinaryX64%=startpe.exe
%BinaryA64%=startpe-arm64.exe
// Explorer-side loader DLL (injected via FolderExtensions) — arch-matched to the binary.
%LoaderX64%=startpe_loader.dll
%LoaderA64%=startpe_loader-arm64.dll
// COM CLSID used to get the loader pulled into Explorer at shell startup.
%LoaderCLSID%={6F3D9B2A-1C4E-4E7A-9B58-2E1D7C0A5F31}
// Base URL for release builds; the arch-specific binary name is appended.
%DownloadURL%=https://github.com/steeb-k/startpe/releases/latest/download/

[Process]
Echo,"Configuring [ StartPE ] as the start menu..."

RunFromRam

If,%cb_AlwaysDownload%,Equal,True,DirDeleteEx,"%ProgramsCache%\%ProgramFolder%"

// ---------------------------------------------------------------------------
// Stage the binary. Prefer a locally provided copy next to the script;
// fall back to downloading a release build.

If,%SourceArch%,Equal,x64,Begin
  Set,%BinaryName%,%BinaryX64%
  Set,%LoaderName%,%LoaderX64%
End
Else,If,%SourceArch%,Equal,ARM64,Begin
  Set,%BinaryName%,%BinaryA64%
  Set,%LoaderName%,%LoaderA64%
End
Else,Halt,"StartPE ERROR: Unsupported processor architecture [%SourceArch%]."

If,Not,ExistFile,"%ProgramsCache%\%ProgramFolder%\%BinaryName%",Run,%ScriptFile%,DownloadProgram
If,Not,ExistFile,"%ProgramsCache%\%ProgramFolder%\%LoaderName%",Run,%ScriptFile%,DownloadProgram
FileCopy,"%ProgramsCache%\%ProgramFolder%\%BinaryName%","%TargetPrograms%\%ProgramFolder%\%BinaryName%"
FileCopy,"%ProgramsCache%\%ProgramFolder%\%LoaderName%","%TargetPrograms%\%ProgramFolder%\%LoaderName%"

Run,%ScriptFile%,Config

[#Config#]
// ===============================================================================================================================
// Name...........: Config
// Description....: Configure StartPE and arrange for it to launch with the shell.
// Remarks........: StartPE config goes in the SOFTWARE hive (HKLM\Software\
//                  StartPE) because PE runs the shell as SYSTEM; the Run key
//                  and Explorer tweaks stay in the Default-user hive. Both are
//                  mounted offline, the same pattern the StartAllBack script uses.
// ===============================================================================================================================
[Config]
Echo,"Configuring StartPE..."

RegHiveLoad,Tmp_Default,%RegDefault%
RegHiveLoad,Tmp_Software,%RegSoftware%

// Run key: honored when Explorer loads a real user profile (classic PE logon).
// StartPE is single-instance, so an Explorer restart relaunching it is harmless.
RegWrite,HKLM,REG_SZ,"Tmp_Default\Software\Microsoft\Windows\CurrentVersion\Run","StartPE","%PEPrograms%\%ProgramFolder%\%BinaryName%"

// Register the StartPE loader DLL as a Drive FolderExtensions COM handler —
// the same load vector StartAllBack uses — so shell32 pulls it into
// explorer.exe early in shell startup. The loader keeps Explorer's shell
// thread alive past the Win11 taskbar init (so the desktop/wallpaper/icons
// appear) and launches startpe.exe. See loader/.
RegWrite,HKLM,REG_SZ,"Tmp_Software\Classes\CLSID\%LoaderCLSID%\InProcServer32","","%PEPrograms%\%ProgramFolder%\%LoaderName%"
RegWrite,HKLM,REG_SZ,"Tmp_Software\Classes\CLSID\%LoaderCLSID%\InProcServer32","ThreadingModel","Apartment"
RegWrite,HKLM,REG_SZ,"Tmp_Software\Classes\Drive\shellex\FolderExtensions\%LoaderCLSID%","","StartPE"
RegWrite,HKLM,REG_DWORD,"Tmp_Software\Classes\Drive\shellex\FolderExtensions\%LoaderCLSID%","DriveMask",255

// winrx-creator / PhoenixPE: WinRxCreator.au3 starts Explorer as SYSTEM; the
// Default-user Run key is not processed on that path. PostShell matches HotSwap
// and other apps that must run after the shell is up. StartPE is
// single-instance, so the loader launching it too is harmless.
AddAutoRun,PostShell,NoWait,"StartPE","%PEPrograms%\%ProgramFolder%\%BinaryName%"

// Stop WinRxCreator.au3 from relaunching Explorer when it exits. On this PE
// Explorer's shell init fail-fasts and exits immediately, so the au3's
// "keep the shell alive" monitor would relaunch it forever (CPU churn / stutter).
// StartPE provides the shell surface, so suppress the relaunch. Requires the
// matching guard in WinRxCreator.au3 (reads HKLM\Software\StartPE\SuppressShellRestart).
RegWrite,HKLM,REG_DWORD,"Tmp_Software\StartPE","SuppressShellRestart",1

// StartPE configuration (see docs/ARCHITECTURE.md for the value reference).
// Written into the SOFTWARE hive (-> HKLM\Software\StartPE at runtime), NOT the
// Default-user hive: PE runs the shell as SYSTEM, whose HKCU is the SYSTEM
// profile and never the offline Default-user hive, so HKCU\Software\StartPE
// would be empty. StartPE reads HKLM first, then overlays HKCU.
RegWrite,HKLM,REG_DWORD,"Tmp_Software\StartPE","TaskbarHeight",%nb_TaskbarHeight%
RegWrite,HKLM,REG_DWORD,"Tmp_Software\StartPE","ButtonMaxWidth",220
RegWrite,HKLM,REG_DWORD,"Tmp_Software\StartPE","MenuWidth",%nb_MenuWidth%
RegWrite,HKLM,REG_DWORD,"Tmp_Software\StartPE","MenuHeight",%nb_MenuHeight%

// 0 = icon-only task buttons (default), 1 = show window titles
If,%cb_TaskbarLabels%,Equal,True,RegWrite,HKLM,REG_DWORD,"Tmp_Software\StartPE","TaskbarLabels",1
Else,RegWrite,HKLM,REG_DWORD,"Tmp_Software\StartPE","TaskbarLabels",0

// 1 = combine windows of the same app into one button (default), 0 = one button per window
If,%cb_TaskbarCombine%,Equal,True,RegWrite,HKLM,REG_DWORD,"Tmp_Software\StartPE","TaskbarCombine",1
Else,RegWrite,HKLM,REG_DWORD,"Tmp_Software\StartPE","TaskbarCombine",0

// 1 = center the start button + task buttons (default), 0 = left-aligned
If,%cb_CenterTaskbar%,Equal,True,RegWrite,HKLM,REG_DWORD,"Tmp_Software\StartPE","CenterTaskbar",1
Else,RegWrite,HKLM,REG_DWORD,"Tmp_Software\StartPE","CenterTaskbar",0

// Start button glyph color (COLORREF 0x00BBGGRR). Default 15790320 = 0x00F0F0F0
// (near-white). Set e.g. 15760384 (0x00F08000) for an accent-blue start button.
RegWrite,HKLM,REG_DWORD,"Tmp_Software\StartPE","StartButtonColor",15096500

// Dark-mode the shell-rendered menus StartPE raises (chiefly the desktop
// right-click context menu, which StartPE hosts in-process). 1 = dark (default),
// 0 = leave light. Uses uxtheme dark app mode; build-gated and fails closed.
RegWrite,HKLM,REG_DWORD,"Tmp_Software\StartPE","DarkMenus",1

// User picture shown on the start menu (circular). Provide a square .bmp
// next to this script as UserPicture.bmp, or leave absent for the default
// person silhouette.
If,ExistFile,"%ScriptDir%\UserPicture.bmp",Begin
  FileCopy,"%ScriptDir%\UserPicture.bmp","%TargetPrograms%\%ProgramFolder%\UserPicture.bmp"
  RegWrite,HKLM,REG_SZ,"Tmp_Software\StartPE","UserPicture","%PEPrograms%\%ProgramFolder%\UserPicture.bmp"
End

// Desktop: on Win11 24H2/25H2 PE, Explorer's modern taskbar init fail-fasts and
// Explorer never builds its own desktop (no Progman -> no wallpaper/icons), so
// StartPE provides the desktop itself. 1 = always own the desktop (skips the
// detection wait; correct for these PE images). Use 0 (auto) only if some boots
// have a working Explorer desktop, or 2 to disable.
RegWrite,HKLM,REG_DWORD,"Tmp_Software\StartPE","OwnDesktop",1

// Optional wallpaper for the StartPE-owned desktop. Provide Wallpaper.png,
// .jpg, or .bmp next to this script (loaded via GDI+, first match wins);
// otherwise the desktop is a solid DesktopColor fill.
If,ExistFile,"%ScriptDir%\Wallpaper.png",Begin
  FileCopy,"%ScriptDir%\Wallpaper.png","%TargetPrograms%\%ProgramFolder%\Wallpaper.png"
  RegWrite,HKLM,REG_SZ,"Tmp_Software\StartPE","Wallpaper","%PEPrograms%\%ProgramFolder%\Wallpaper.png"
End
Else,If,ExistFile,"%ScriptDir%\Wallpaper.jpg",Begin
  FileCopy,"%ScriptDir%\Wallpaper.jpg","%TargetPrograms%\%ProgramFolder%\Wallpaper.jpg"
  RegWrite,HKLM,REG_SZ,"Tmp_Software\StartPE","Wallpaper","%PEPrograms%\%ProgramFolder%\Wallpaper.jpg"
End
Else,If,ExistFile,"%ScriptDir%\Wallpaper.bmp",Begin
  FileCopy,"%ScriptDir%\Wallpaper.bmp","%TargetPrograms%\%ProgramFolder%\Wallpaper.bmp"
  RegWrite,HKLM,REG_SZ,"Tmp_Software\StartPE","Wallpaper","%PEPrograms%\%ProgramFolder%\Wallpaper.bmp"
End
// Solid desktop background when no wallpaper bitmap (COLORREF 0x00BBGGRR).
RegWrite,HKLM,REG_DWORD,"Tmp_Software\StartPE","DesktopColor",3158560

// Built-in desktop namespace icons (This PC, Home, Network, Control Panel,
// Recycle Bin). 0 = hidden (default; only your real Desktop / Public Desktop
// shortcuts show), 1 = show them.
RegWrite,HKLM,REG_DWORD,"Tmp_Software\StartPE","ShowSystemDesktopIcons",0

// Desktop icon layout: positions are stored as x,y,Name lines in
// desktop-layout.txt next to startpe.exe. StartPE writes it as you arrange
// icons; drop the captured file next to this script to bake those positions in.
If,ExistFile,"%ScriptDir%\desktop-layout.txt",FileCopy,"%ScriptDir%\desktop-layout.txt","%TargetPrograms%\%ProgramFolder%\desktop-layout.txt"

// Quiet down the Win11 taskbar Explorer would otherwise populate.
// (StartPE hides the window itself; these just avoid wasted work at logon.)
RegWrite,HKLM,REG_DWORD,"Tmp_Default\Software\Microsoft\Windows\CurrentVersion\Search","SearchboxTaskbarMode",0
RegWrite,HKLM,REG_DWORD,"Tmp_Default\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced","ShowTaskViewButton",0
RegWrite,HKLM,REG_DWORD,"Tmp_Default\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced","TaskbarMn",0

// Default to dark mode so theme-aware apps come up dark on their own. This is
// just the documented system setting (no injection): apps that honor it follow
// it, apps that ignore it stay light. StartPE's own UI is dark regardless.
RegWrite,HKLM,REG_DWORD,"Tmp_Default\Software\Microsoft\Windows\CurrentVersion\Themes\Personalize","AppsUseLightTheme",0
RegWrite,HKLM,REG_DWORD,"Tmp_Default\Software\Microsoft\Windows\CurrentVersion\Themes\Personalize","SystemUsesLightTheme",0

RegHiveUnload,Tmp_Default
RegHiveUnload,Tmp_Software

[#DownloadProgram#]
// ===============================================================================================================================
// Name...........: DownloadProgram
// Description....: Download a release build of StartPE.
// ===============================================================================================================================
[DownloadProgram]
If,%DownloadURL%,Equal,"",Halt,"StartPE ERROR: No local copy of [%BinaryName%] found in [%ProgramsCache%\%ProgramFolder%] and no %DownloadURL% is configured. Build it with cargo and place it there, or set the download URL."
Echo,"Downloading the latest version of %ScriptTitle%..."
WebGet,"%DownloadURL%%BinaryName%","%ProgramsCache%\%ProgramFolder%\%BinaryName%",NOERR
If,Not,#r,Equal,200,Halt,"Download failed: The code returned was [#r]."
WebGet,"%DownloadURL%%LoaderName%","%ProgramsCache%\%ProgramFolder%\%LoaderName%",NOERR
If,Not,#r,Equal,200,Halt,"Download failed (loader): The code returned was [#r]."

[#ClearDownloadCache#]
[ClearDownloadCache]
DirDeleteEx,"%ProgramsCache%\%ProgramFolder%"

[#SetDefaultOptions#]
[SetDefaultOptions]
System,Cursor,Wait
WriteInterface,Value,%ScriptFile%,Interface,cb_AlwaysDownload,False
WriteInterface,Value,%ScriptFile%,Interface,nb_TaskbarHeight,40
WriteInterface,Value,%ScriptFile%,Interface,cb_TaskbarLabels,False
WriteInterface,Value,%ScriptFile%,Interface,cb_TaskbarCombine,True
WriteInterface,Value,%ScriptFile%,Interface,cb_CenterTaskbar,True
WriteInterface,Value,%ScriptFile%,Interface,nb_MenuWidth,420
WriteInterface,Value,%ScriptFile%,Interface,nb_MenuHeight,360
System,Cursor,Normal

[#ShowScriptInfo#]
[ShowScriptInfo]
Message,"StartPE is a free, open source (GPLv3) taskbar and start menu for Windows PE.#$x#$xhttps://github.com/steeb-k/startpe"

